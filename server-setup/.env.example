# MEDI SAP Sync Server Configuration
# Copy this file to .env and edit the values

SAP_HOST=192.168.27.37
SAP_PORT=50000
SAP_COMPANY=JJEZ
SAP_USER=nemi
SAP_PASSWORD=YOUR_PASSWORD_HERE
SAP_MONTHS=18

# Google Apps Script URL (deployed Web App)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Sync interval in milliseconds (default: 1 hour)
SYNC_INTERVAL_MS=3600000

# Server port
PORT=8080

# Optional API token for manual sync trigger
API_TOKEN=
